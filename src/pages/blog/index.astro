---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['All', ...new Set(posts.map(p => p.data.category))];

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Base title="Blog — syhai.xyz">

  <div class="container--wide"><div class="rule-thick"></div></div>

  <div class="blog-header">
    <div class="container--wide">
      <h1 class="fade-up-1" data-lang="en">All Posts</h1>
      <h1 class="fade-up-1" data-lang="vn">Tất cả bài viết</h1>
      <p class="fade-up-2" data-lang="en">Everything I learn about AI and crypto — posted publicly.</p>
      <p class="fade-up-2" data-lang="vn">Tất cả những gì tôi học về AI và crypto — chia sẻ công khai.</p>
    </div>
  </div>

  <div class="container--wide" style="padding-bottom:4rem">

    <div class="filter-row fade-up-2">
      {categories.map(cat => (
        <button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-cat={cat} onclick="filterPosts(this)">
          {cat}
        </button>
      ))}
    </div>

    <div id="post-list">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-row" data-cat={post.data.category}>
          <div class="post-row__left">
            <span class="tag">{post.data.category}</span>
            <h2 class="post-row__title" data-lang="en">{post.data.title}</h2>
            <h2 class="post-row__title" data-lang="vn">{post.data.titleVN ?? post.data.title}</h2>
            <p class="post-row__desc" data-lang="en">{post.data.description}</p>
            <p class="post-row__desc" data-lang="vn">{post.data.descriptionVN ?? post.data.description}</p>
          </div>
          <div class="post-row__meta">
            <span class="mono muted">{fmt(post.data.pubDate)}</span>
            <span class="mono muted" data-lang="en">{post.data.readTime} min read</span>
            <span class="mono muted" data-lang="vn">{post.data.readTime} phút đọc</span>
          </div>
        </a>
      ))}
    </div>

  </div>

</Base>

<style>
.blog-header {
  padding: 2.5rem 0 2rem;
  border-bottom: 0.5px solid var(--rule);
}
.blog-header h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.06;
}
.blog-header p {
  font-size: 1rem;
  color: var(--ink2);
  margin-top: 0.6rem;
  font-family: var(--source);
}

.mono  { font-family: var(--mono); }
.muted { color: var(--b300); font-size: 0.66rem; }

/* Filter row */
.filter-row {
  display: flex;
  gap: 0;
  flex-wrap: wrap;
  padding: 1.5rem 0 0;
  border-bottom: 0.5px solid var(--rule);
  margin-bottom: 0;
}
.filter-btn {
  font-family: var(--mono);
  font-size: 0.64rem;
  padding: 8px 16px;
  border: none;
  border-right: 0.5px solid var(--rule);
  background: transparent;
  color: var(--b400);
  cursor: pointer;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: all 0.12s;
  font-weight: 500;
}
.filter-btn:first-child { border-left: 0.5px solid var(--rule); }
.filter-btn:hover { color: var(--ink); background: var(--b100); }
.filter-btn.active { background: var(--ink); color: #fff; border-color: var(--ink); }

/* Post rows — text-only */
.post-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 2rem;
  padding: 1.75rem 0;
  border-bottom: 0.5px solid var(--rule);
  color: inherit;
}
.post-row:hover { color: inherit; }
.post-row:hover .post-row__title { color: var(--accent); }
.post-row.hidden { display: none; }

.post-row__left { flex: 1; min-width: 0; }
.post-row__left .tag { margin-bottom: 0.4rem; }

.post-row__title {
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  font-weight: 800;
  color: var(--ink);
  line-height: 1.15;
  letter-spacing: -0.03em;
  margin-bottom: 0.45rem;
  transition: color 0.15s;
}
.post-row__desc {
  font-size: 0.88rem;
  color: var(--ink2);
  line-height: 1.62;
  font-family: var(--source);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 60ch;
}

.post-row__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 3px;
  padding-top: 4px;
  flex-shrink: 0;
  white-space: nowrap;
}

@media (max-width: 600px) {
  .post-row { flex-direction: column; gap: 0.5rem; }
  .post-row__meta { flex-direction: row; align-items: center; gap: 0.5rem; }
}
</style>

<script>
function filterPosts(btn: HTMLButtonElement) {
  const cat = btn.dataset.cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.post-row').forEach((row: Element) => {
    const el = row as HTMLElement;
    el.classList.toggle('hidden', cat !== 'All' && el.dataset.cat !== cat);
  });
}
</script>
