---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['All', ...new Set(posts.map(p => p.data.category))];

function fmtShort(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Base title="Blog — syhai.xyz">

  <div class="container--wide"><div class="rule-thick"></div></div>

  <div class="blog-header grid-paper">
    <div class="container--wide">
      <h1 class="headline-block fade-up-1">ALL<span class="headline-block__joiner">_</span>POSTS</h1>
    </div>
  </div>

  <div class="container--wide" style="padding-bottom:4rem">

    <div class="filter-bar fade-up-2">
      <div class="filter-row">
        {categories.map(cat => (
          <button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-cat={cat} onclick="filterPosts(this)">
            {cat}
          </button>
        ))}
      </div>
      <input id="search-input" class="search-input" type="search" placeholder="Search posts…" />
    </div>

    <div id="post-list" class="post-card-grid">
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`} class="post-card" data-cat={post.data.category} data-title={post.data.title.toLowerCase()}>
          <div class="chip-row">
            {i === 0 && <span class="chip chip--status">Latest</span>}
            <span class="chip chip--outline">{post.data.category}</span>
          </div>
          <h3 class="post-card__title">{post.data.title}</h3>
          <div class="stat-grid">
            <div class="stat-item"><span class="stat-item__value">{post.data.readTime} min</span><span class="stat-item__label">Read</span></div>
            <div class="stat-item"><span class="stat-item__value">{fmtShort(post.data.pubDate)}</span><span class="stat-item__label">Published</span></div>
          </div>
          <span class="card-arrow">→</span>
        </a>
      ))}
    </div>

  </div>

</Base>

<style>
.blog-header {
  padding: 2.5rem 0 1.5rem;
  border-bottom: 0.5px solid var(--rule);
}
.blog-header h1 { margin: 0; }

.filter-row {
  display: flex;
  flex-wrap: wrap;
}
.filter-btn {
  font-family: var(--mono);
  font-size: 0.64rem;
  padding: 8px 16px;
  border: none;
  border-right: 0.5px solid var(--rule);
  background: transparent;
  color: var(--b400);
  cursor: pointer;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: all 0.12s;
  font-weight: 500;
  border-top: 0.5px solid var(--rule);
  border-bottom: 0.5px solid var(--rule);
}
.filter-btn:first-child { border-left: 0.5px solid var(--rule); }
.filter-btn:hover { color: var(--ink); background: var(--b100); }
.filter-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

.post-card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 0.5px solid var(--rule);
  border-left: 0.5px solid var(--rule);
  margin-top: 1.5rem;
}
.post-card {
  position: relative;
  display: block;
  background: var(--bg);
  color: inherit;
  padding: 1.4rem 1.4rem 3rem;
  border-right: 0.5px solid var(--rule);
  border-bottom: 0.5px solid var(--rule);
  transition: background 0.15s;
}
.post-card:hover { background: var(--b100); }
.post-card:hover .card-arrow { background: var(--accent); color: #fff; border-color: var(--accent); }
.post-card.hidden { display: none; }
.post-card .chip-row { margin-bottom: 0.9rem; }
.post-card__title {
  font-family: var(--playfair);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.3;
  margin: 0 0 1.1rem;
}

@media (max-width: 800px) {
  .post-card-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .post-card-grid { grid-template-columns: 1fr; }
  .search-input { width: 100%; }
}
</style>

<script>
function filterPosts(btn: HTMLButtonElement) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

function applyFilters() {
  const activeBtn = document.querySelector<HTMLButtonElement>('.filter-btn.active');
  const cat = activeBtn?.dataset.cat ?? 'All';
  const query = (document.getElementById('search-input') as HTMLInputElement | null)?.value.trim().toLowerCase() ?? '';

  document.querySelectorAll<HTMLElement>('.post-card').forEach(card => {
    const matchesCat = cat === 'All' || card.dataset.cat === cat;
    const matchesQuery = !query || (card.dataset.title ?? '').includes(query);
    card.classList.toggle('hidden', !(matchesCat && matchesQuery));
  });
}

(window as any).filterPosts = filterPosts;
document.getElementById('search-input')?.addEventListener('input', applyFilters);
</script>
