---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['All', ...new Set(posts.map(p => p.data.category))];
---

<Base title="Blog — syhai.xyz">

  <div class="container--wide"><div class="rule-thick"></div></div>

  <div class="blog-header">
    <div class="container--wide">
      <h1 class="fade-up-1" data-lang="en">All Posts</h1>
      <h1 class="fade-up-1" data-lang="vn">Tất cả bài viết</h1>
    </div>
  </div>

  <div class="container--wide" style="padding-bottom:4rem">

    <div class="filter-row fade-up-2">
      {categories.map(cat => (
        <button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-cat={cat} onclick="filterPosts(this)">
          {cat}
        </button>
      ))}
    </div>

    <div id="post-list" class="post-list">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-row" data-cat={post.data.category}>
          <span class="tag post-row__cat">{post.data.category}</span>
          <span class="post-row__title" data-lang="en">{post.data.title}</span>
          <span class="post-row__title" data-lang="vn">{post.data.titleVN ?? post.data.title}</span>
        </a>
      ))}
    </div>

  </div>

</Base>

<style>
.blog-header {
  padding: 2.5rem 0 1.5rem;
  border-bottom: 0.5px solid var(--rule);
}
.blog-header h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.06;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  padding: 1.5rem 0 0;
  border-bottom: 0.5px solid var(--rule);
}
.filter-btn {
  font-family: var(--mono);
  font-size: 0.64rem;
  padding: 8px 16px;
  border: none;
  border-right: 0.5px solid var(--rule);
  background: transparent;
  color: var(--b400);
  cursor: pointer;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: all 0.12s;
  font-weight: 500;
}
.filter-btn:first-child { border-left: 0.5px solid var(--rule); }
.filter-btn:hover { color: var(--ink); background: var(--b100); }
.filter-btn.active { background: var(--ink); color: #fff; border-color: var(--ink); }

.post-list { border-top: 0.5px solid var(--rule); }

.post-row {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 1.1rem 0;
  border-bottom: 0.5px solid var(--rule);
  color: inherit;
}
.post-row:hover .post-row__title { color: var(--accent); }
.post-row.hidden { display: none; }
.post-row__cat { flex-shrink: 0; }
.post-row__title {
  font-family: var(--playfair);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.3;
  transition: color 0.15s;
}

@media (max-width: 600px) {
  .post-row__cat { display: none; }
}
</style>

<script>
function filterPosts(btn: HTMLButtonElement) {
  const cat = btn.dataset.cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.post-row').forEach((row: Element) => {
    const el = row as HTMLElement;
    el.classList.toggle('hidden', cat !== 'All' && el.dataset.cat !== cat);
  });
}
</script>
