---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const rest = posts.slice(0, 6);
---

<Base title="syhai.xyz — AI & Crypto Research">

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="container--wide">
      <h1 class="hero__name">Sy Hai</h1>
      <p class="hero__bio" data-lang="en">
        I work at the intersection of AI, crypto trading, and quantitative research —
        building systems that give individual traders access to tools that used to require a team.
      </p>
      <p class="hero__bio" data-lang="vn">
        Tôi làm việc tại giao điểm giữa AI, giao dịch crypto và nghiên cứu định lượng —
        xây dựng hệ thống giúp trader cá nhân tiếp cận công cụ chỉ đội ngũ lớn mới có.
      </p>
      <span class="hero__note" data-lang="en">Learning in public.</span>
      <span class="hero__note" data-lang="vn">Học hỏi công khai.</span>
    </div>
  </section>

  <!-- ── LATEST ── -->
  {rest.length > 0 && (
    <section class="latest">
      <div class="container--wide">
        <div class="section-row">
          <span class="section-label" data-lang="en">Latest</span>
          <span class="section-label" data-lang="vn">Mới nhất</span>
          <div class="rule-thin" style="flex:1"></div>
          <a href="/blog" class="view-all" data-lang="en">View all →</a>
          <a href="/blog" class="view-all" data-lang="vn">Xem tất cả →</a>
        </div>
        <div class="post-list">
          {rest.map(post => (
            <a href={`/blog/${post.slug}`} class="post-list__row">
              <span class="tag post-list__cat">{post.data.category}</span>
              <span class="post-list__title" data-lang="en">{post.data.title}</span>
              <span class="post-list__title" data-lang="vn">{post.data.titleVN ?? post.data.title}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── ABOUT STRIP ── -->
  <section class="about">
    <div class="container--wide">
      <div class="about__inner">
        <div class="about__avatar">SH</div>
        <div class="about__text">
          <div class="about__name">Sy Hai</div>
          <div class="about__bio" data-lang="en">AI · Crypto · Poker · Learning in public</div>
          <div class="about__bio" data-lang="vn">AI · Crypto · Poker · Học hỏi công khai</div>
        </div>
        <div class="about__links">
          <a href="https://x.com/syngochai" target="_blank" rel="noopener" class="btn">X →</a>
          <a href="/about" class="btn" data-lang="en">About</a>
          <a href="/about" class="btn" data-lang="vn">Về tôi</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
/* ── HERO ── */
.hero {
  padding: 3.5rem 0 3rem;
  border-bottom: 0.5px solid var(--rule);
}
.hero__name {
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 900;
  letter-spacing: -0.05em;
  line-height: 0.95;
  margin-bottom: 1.5rem;
  color: var(--ink);
}
.hero__bio {
  font-family: var(--source);
  font-size: clamp(1rem, 1.4vw, 1.12rem);
  color: var(--ink2);
  line-height: 1.72;
  max-width: 540px;
  margin-bottom: 0.75rem;
}
.hero__note {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--b400);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  display: block;
  margin-top: 0.25rem;
}

/* ── SECTION ROW ── */
.section-row { display: flex; align-items: center; gap: 12px; padding: 2rem 0 1.25rem; }
.view-all {
  font-family: var(--mono);
  font-size: 0.66rem;
  color: var(--b400);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
}
.view-all:hover { color: var(--accent); }

/* ── LATEST ── */
.latest { padding-bottom: 3rem; }
.post-list { border-top: 0.5px solid var(--rule); }
.post-list__row {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 1.1rem 0;
  border-bottom: 0.5px solid var(--rule);
  color: inherit;
}
.post-list__row:hover .post-list__title { color: var(--accent); }
.post-list__cat { flex-shrink: 0; }
.post-list__title {
  font-family: var(--playfair);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.02em;
  line-height: 1.3;
  transition: color 0.15s;
}

/* ── ABOUT ── */
.about { padding: 2rem 0 3.5rem; }
.about__inner {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  border: 0.5px solid var(--rule);
  padding: 1.5rem 1.75rem;
  background: var(--b100);
}
.about__avatar {
  width: 44px;
  height: 44px;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--playfair);
  font-size: 0.82rem;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
}
.about__text { flex: 1; }
.about__name { font-size: 1rem; font-weight: 800; font-family: var(--playfair); margin-bottom: 3px; letter-spacing: -0.02em; }
.about__bio  { font-family: var(--mono); font-size: 0.66rem; color: var(--b400); letter-spacing: 0.04em; }
.about__links { display: flex; gap: 0.5rem; }

@media (max-width: 600px) {
  .about__links { display: none; }
  .post-list__cat { display: none; }
}
</style>
