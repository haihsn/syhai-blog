---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const grid     = posts.slice(1, 4);

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Base title="syhai.xyz — AI & Crypto Research">

  <div class="container--wide"><div class="rule-thick fade-up"></div></div>

  <!-- FEATURED -->
  {featured && (
    <section class="featured fade-up-1">
      <div class="container--wide">
        <a href={`/blog/${featured.slug}`} class="featured__card">

          <!-- LEFT: image -->
          <div class="featured__img img-frame">
            {featured.data.cover
              ? <img src={featured.data.cover} alt={featured.data.title} />
              : <div class="img-frame__placeholder">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                    <rect x="3" y="8" width="30" height="20" rx="1" stroke="#999" stroke-width="1.5"/>
                    <path d="M3 17l8 7 7-6 10 7" stroke="#999" stroke-width="1"/>
                    <circle cx="11" cy="14" r="3" fill="#E5E5E5"/>
                  </svg>
                  <span data-lang="en">Cover image</span>
                  <span data-lang="vn">Ảnh bìa</span>
                </div>
            }
          </div>

          <!-- RIGHT: category + title + desc + meta -->
          <div class="featured__body">
            <span class="tag">{featured.data.category}</span>
            <h1 class="featured__title" data-lang="en">{featured.data.title}</h1>
            <h1 class="featured__title" data-lang="vn">{featured.data.titleVN ?? featured.data.title}</h1>
            <p class="featured__desc" data-lang="en">{featured.data.description}</p>
            <p class="featured__desc" data-lang="vn">{featured.data.descriptionVN ?? featured.data.description}</p>
            <div class="featured__footer">
              <span class="featured__meta">
                <span class="mono">{fmt(featured.data.pubDate)}</span>
                <span class="mono mid-dot">·</span>
                <span class="mono" data-lang="en">{featured.data.readTime} min read</span>
                <span class="mono" data-lang="vn">{featured.data.readTime} phút đọc</span>
              </span>
              <span class="featured__cta">
                <span data-lang="en">Read →</span>
                <span data-lang="vn">Đọc →</span>
              </span>
            </div>
          </div>

        </a>
      </div>
    </section>
  )}

  <!-- LATEST SECTION HEADER -->
  <div class="container--wide section-row fade-up-2">
    <span class="section-label" data-lang="en">Latest</span>
    <span class="section-label" data-lang="vn">Mới nhất</span>
    <div class="rule-thin" style="flex:1"></div>
    <a href="/blog" class="view-all" data-lang="en">View all →</a>
    <a href="/blog" class="view-all" data-lang="vn">Xem tất cả →</a>
  </div>

  {grid.length > 0 && (
    <section class="post-grid-section fade-up-3">
      <div class="container--wide">
        <div class="post-grid">
          {grid.map(post => (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-card__img img-frame">
                {post.data.cover
                  ? <img src={post.data.cover} alt={post.data.title} />
                  : <div class="img-frame__placeholder img-frame__placeholder--sm">
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                        <rect x="2" y="5" width="20" height="14" rx="1" stroke="#999" stroke-width="1.5"/>
                        <path d="M2 11l5 4 4-3 6 4" stroke="#999" stroke-width="1"/>
                        <circle cx="7.5" cy="9" r="1.5" fill="#E5E5E5"/>
                      </svg>
                    </div>
                }
              </div>
              <div class="post-card__body">
                <span class="tag">{post.data.category}</span>
                <h2 class="post-card__title" data-lang="en">{post.data.title}</h2>
                <h2 class="post-card__title" data-lang="vn">{post.data.titleVN ?? post.data.title}</h2>
                <p class="post-card__desc" data-lang="en">{post.data.description}</p>
                <p class="post-card__desc" data-lang="vn">{post.data.descriptionVN ?? post.data.description}</p>
                <div class="post-card__meta">
                  <span class="mono muted">{fmt(post.data.pubDate)}</span>
                  <span class="mono muted" data-lang="en">{post.data.readTime} min</span>
                  <span class="mono muted" data-lang="vn">{post.data.readTime} phút</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="container--wide" style="padding-top: 1rem;"><div class="rule-thick"></div></div>

  <!-- WHAT I'M BUILDING -->
  <section class="building" id="building">
    <div class="container--wide">
      <div class="section-row" style="margin-bottom:1.5rem; padding-top:2rem;">
        <span class="section-label" data-lang="en">What I'm building</span>
        <span class="section-label" data-lang="vn">Những gì tôi đang xây dựng</span>
        <div class="rule-thin" style="flex:1"></div>
      </div>
      <div class="building__grid">

        <div class="building__card">
          <span class="building__status building__status--live" data-lang="en">● Live</span>
          <span class="building__status building__status--live" data-lang="vn">● Đang hoạt động</span>
          <h3 class="building__title" data-lang="en">AI Trading Signal System</h3>
          <h3 class="building__title" data-lang="vn">Hệ thống tín hiệu giao dịch AI</h3>
          <p class="building__desc" data-lang="en">Automated signal engine built with Claude. Runs on Binance data, fires alerts to Telegram.</p>
          <p class="building__desc" data-lang="vn">Hệ thống tín hiệu tự động dùng Claude. Chạy trên dữ liệu Binance, gửi cảnh báo qua Telegram.</p>
        </div>

        <div class="building__card">
          <span class="building__status building__status--building" data-lang="en">◐ Building</span>
          <span class="building__status building__status--building" data-lang="vn">◐ Đang xây dựng</span>
          <h3 class="building__title" data-lang="en">TikTok — AI for Traders</h3>
          <h3 class="building__title" data-lang="vn">TikTok — AI cho trader</h3>
          <p class="building__desc" data-lang="en">Short-form videos teaching how to use Claude for crypto research. Posting weekly.</p>
          <p class="building__desc" data-lang="vn">Video ngắn hướng dẫn dùng Claude cho nghiên cứu crypto. Đăng hàng tuần.</p>
        </div>

        <div class="building__card">
          <span class="building__status building__status--soon" data-lang="en">○ Coming soon</span>
          <span class="building__status building__status--soon" data-lang="vn">○ Sắp ra mắt</span>
          <h3 class="building__title" data-lang="en">Crypto Research Newsletter</h3>
          <h3 class="building__title" data-lang="vn">Bản tin nghiên cứu crypto</h3>
          <p class="building__desc" data-lang="en">Weekly AI-powered market digest for traders. Launching Q2 2025.</p>
          <p class="building__desc" data-lang="vn">Tổng hợp thị trường hàng tuần dùng AI. Ra mắt Q2 2025.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ABOUT STRIP -->
  <section class="about">
    <div class="container--wide">
      <div class="about__inner">
        <div class="about__avatar">SH</div>
        <div class="about__text">
          <div class="about__name">Sy Hai</div>
          <div class="about__bio" data-lang="en">AI · Crypto · Poker · Learning in public</div>
          <div class="about__bio" data-lang="vn">AI · Crypto · Poker · Học hỏi công khai</div>
        </div>
        <div class="about__links">
          <a href="https://x.com/syngochai" target="_blank" rel="noopener" class="btn">X →</a>
          <a href="/about" class="btn" data-lang="en">About</a>
          <a href="/about" class="btn" data-lang="vn">Về tôi</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
/* ── FEATURED ── */
.featured { padding: 0; }

.featured__card {
  display: grid;
  grid-template-columns: 55% 45%;
  color: inherit;
  border-bottom: 0.5px solid var(--rule);
}
.featured__card:hover { color: inherit; }
.featured__card:hover .featured__title { color: var(--accent); }

.featured__img {
  height: 240px;
  border-right: 0.5px solid var(--rule);
}

.featured__body {
  padding: 2.5rem 2.5rem 2rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1rem;
}

.featured__title {
  font-size: clamp(1.6rem, 2.8vw, 2.6rem);
  font-weight: 800;
  letter-spacing: -0.035em;
  line-height: 1.08;
  color: var(--ink);
  transition: color 0.15s;
}

.featured__desc {
  font-size: 1rem;
  color: var(--ink2);
  line-height: 1.65;
  font-family: var(--source);
}

.featured__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 0.5px solid var(--rule);
  padding-top: 1rem;
  margin-top: auto;
}
.featured__meta {
  display: flex;
  align-items: center;
  gap: 6px;
}
.featured__meta .mono { font-family: var(--mono); font-size: 0.66rem; color: var(--b300); }
.mid-dot { color: var(--b200) !important; }

.featured__cta {
  font-family: var(--mono);
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 0.04em;
}

/* ── SECTION ROW ── */
.section-row { display: flex; align-items: center; gap: 12px; padding: 2rem 0 1rem; }
.mono { font-family: var(--mono); }
.muted { color: var(--b300); font-size: 0.66rem; }
.view-all {
  font-family: var(--mono);
  font-size: 0.66rem;
  color: var(--b400);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
  font-weight: 500;
}
.view-all:hover { color: var(--accent); }

/* ── POST GRID ── */
.post-grid-section { padding: 0 0 3rem; }
.post-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.post-card {
  display: block;
  color: inherit;
  background: var(--paper);
  border: 0.5px solid var(--rule);
  transition: background 0.12s;
}
.post-card:hover { color: inherit; background: #fafafa; }
.post-card:hover .post-card__title { color: var(--accent); }

.post-card__img {
  height: 180px;
  border-bottom: 0.5px solid var(--rule);
}
.img-frame__placeholder--sm {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: var(--b100);
}

.post-card__body { padding: 1.25rem 1.25rem 1rem; }
.post-card__body .tag { margin-bottom: 0.5rem; }

.post-card__title {
  font-family: var(--playfair);
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--ink);
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin-bottom: 0.5rem;
  transition: color 0.15s;
}
.post-card__desc {
  font-size: 0.82rem;
  color: var(--ink2);
  line-height: 1.55;
  font-family: var(--source);
  margin-bottom: 0.75rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.post-card__meta {
  display: flex;
  gap: 0.5rem;
  border-top: 0.5px solid var(--rule);
  padding-top: 0.6rem;
}

/* ── BUILDING ── */
.building { padding: 1rem 0 2.5rem; }
.building__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 0.5px solid var(--rule);
  border-right: none;
}
.building__card {
  border-right: 0.5px solid var(--rule);
  padding: 1.5rem 1.5rem 1.25rem;
}
.building__status {
  font-family: var(--mono);
  font-size: 0.64rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: block;
  margin-bottom: 0.75rem;
  font-weight: 600;
}
.building__status--live     { color: #16a34a; }
.building__status--building { color: var(--b400); }
.building__status--soon     { color: var(--b300); }
.building__title {
  font-family: var(--playfair);
  font-size: 1rem;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 0.5rem;
  line-height: 1.2;
  letter-spacing: -0.02em;
}
.building__desc {
  font-size: 0.82rem;
  color: var(--ink2);
  line-height: 1.55;
  font-family: var(--source);
}

/* ── ABOUT ── */
.about { padding: 2rem 0 3.5rem; }
.about__inner {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  border: 0.5px solid var(--rule);
  padding: 1.5rem 1.75rem;
  background: var(--b100);
}
.about__avatar {
  width: 44px;
  height: 44px;
  border-radius: 0;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--playfair);
  font-size: 0.82rem;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
  letter-spacing: -0.01em;
}
.about__text { flex: 1; }
.about__name { font-size: 1rem; font-weight: 800; font-family: var(--playfair); margin-bottom: 3px; letter-spacing: -0.02em; }
.about__bio  { font-family: var(--mono); font-size: 0.66rem; color: var(--b400); letter-spacing: 0.04em; }
.about__links { display: flex; gap: 0.5rem; }

@media (max-width: 900px) {
  .post-grid { grid-template-columns: 1fr 1fr; }
  .building__grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 700px) {
  .featured__card { grid-template-columns: 1fr; }
  .featured__img { min-height: 220px; border-right: none; border-bottom: 0.5px solid var(--rule); }
  .featured__body { padding: 1.5rem; }
}
@media (max-width: 600px) {
  .post-grid { grid-template-columns: 1fr; gap: 1rem; }
  .building__grid { grid-template-columns: 1fr; }
  .about__links { display: none; }
}
</style>
