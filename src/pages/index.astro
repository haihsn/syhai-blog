---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// BANNER — swap this one line when you have your file ready:
//   image:  const BANNER = '/banner.jpg'
//   gif:    const BANNER = '/banner.gif'
//   video:  const BANNER = '/banner.mp4'
const BANNER = '';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="syhai.xyz — AI & Crypto Research">

  <div class="home">

    <!-- LEFT: sticky banner slot -->
    <aside class="home__banner">
      {BANNER
        ? (BANNER.match(/\.(mp4|webm)$/i)
            ? <video src={BANNER} autoplay loop muted playsinline class="banner-media" />
            : <img src={BANNER} alt="Sy Hai" class="banner-media" />)
        : <div class="banner-placeholder"><blockquote class="banner-quote">"Being right and winning are not the same game."</blockquote></div>
      }
    </aside>

    <!-- RIGHT: post title list -->
    <div class="home__posts">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-row">
          <span class="post-row__title">{post.data.title}</span>
        </a>
      ))}
    </div>

  </div>

</Base>

<style>
/* ── TWO-COLUMN HOME ── */
.home {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.75rem;
  display: grid;
  grid-template-columns: 32% 1fr;
  overflow: hidden;
}

/* LEFT — sticky banner */
.home__banner {
  position: sticky;
  top: 60px;
  min-height: 260px;
  align-self: start;
  border-right: 0.5px solid var(--rule);
  overflow: hidden;
}

.banner-media {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.banner-placeholder {
  width: 100%;
  min-height: 260px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--b100);
  text-align: center;
  padding: 2rem;
}
.banner-quote {
  font-family: var(--source);
  font-size: 1.05rem;
  font-style: italic;
  font-weight: 400;
  color: var(--ink2);
  line-height: 1.65;
  letter-spacing: 0;
  border: none;
  padding: 0;
  margin: 0;
  text-align: center;
}

/* RIGHT — title list */
.home__posts {
  border-top: 0.5px solid var(--rule);
}

.post-row {
  display: block;
  padding: 0.65rem 1.5rem;
  border-bottom: 0.5px solid var(--rule);
  color: var(--ink);
  font-family: var(--playfair);
  font-size: 1.25rem;
  font-weight: 500;
  line-height: 1.4;
  letter-spacing: -0.01em;
}
.post-row__title { transition: background 0.12s, color 0.12s; }
.post-row:hover .post-row__title {
  background: var(--accent);
  color: #fff;
  box-decoration-break: clone;
  -webkit-box-decoration-break: clone;
}

/* Mobile: stack vertically, banner on top (not sticky) */
@media (max-width: 700px) {
  .home { grid-template-columns: 1fr; }

  .home__banner {
    position: relative;
    top: 0;
    height: 56vw;
    min-height: 200px;
    max-height: 300px;
    border-right: none;
    border-bottom: 0.5px solid var(--rule);
  }

  .post-row {
    padding: 0.6rem 0;
    font-size: 1.1rem;
  }
}
</style>
