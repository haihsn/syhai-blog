---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// BANNER — swap this one line when you have your file ready:
//   image:  const BANNER = '/banner.jpg'
//   gif:    const BANNER = '/banner.gif'
//   video:  const BANNER = '/banner.mp4'
const BANNER = '';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="syhai.xyz — AI & Crypto Research">

  <div class="home">

    <!-- LEFT: sticky banner slot -->
    <aside class="home__banner">
      {BANNER
        ? (BANNER.match(/\.(mp4|webm)$/i)
            ? <video src={BANNER} autoplay loop muted playsinline class="banner-media" />
            : <img src={BANNER} alt="Sy Hai" class="banner-media" />)
        : <div class="banner-placeholder"><span>Add your image / gif / video here</span></div>
      }
    </aside>

    <!-- RIGHT: post title list -->
    <div class="home__posts">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-row">
          <span data-lang="en">{post.data.title}</span>
          <span data-lang="vn">{post.data.titleVN ?? post.data.title}</span>
        </a>
      ))}
    </div>

  </div>

</Base>

<style>
/* ── TWO-COLUMN HOME ── */
.home {
  display: grid;
  grid-template-columns: 32% 1fr;
  min-height: calc(100vh - 100px); /* 100px ≈ sticky nav height */
}

/* LEFT — sticky banner */
.home__banner {
  position: sticky;
  top: 100px;                        /* flush below sticky nav */
  height: calc(100vh - 100px);
  border-right: 0.5px solid var(--rule);
  overflow: hidden;
}

.banner-media {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
  text-align: center;
  padding: 2rem;
}
.banner-placeholder span {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: #666;
  letter-spacing: 0.06em;
  line-height: 1.8;
}

/* RIGHT — title list */
.home__posts {
  border-top: 0.5px solid var(--rule);
}

.post-row {
  display: block;
  padding: 1.6rem 2rem;
  border-bottom: 0.5px solid var(--rule);
  color: var(--ink);
  font-family: var(--source);
  font-size: clamp(1.05rem, 1.7vw, 1.45rem);
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: -0.01em;
  transition: color 0.15s;
}
.post-row:hover { color: var(--accent); }

/* Mobile: stack vertically, banner on top (not sticky) */
@media (max-width: 700px) {
  .home { grid-template-columns: 1fr; }

  .home__banner {
    position: relative;
    top: 0;
    height: 56vw;
    min-height: 200px;
    max-height: 300px;
    border-right: none;
    border-bottom: 0.5px solid var(--rule);
  }

  .post-row {
    padding: 1.2rem 0;
    font-size: 1.05rem;
  }
}
</style>
