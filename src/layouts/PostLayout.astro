---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
  bodyVNHtml?: string | null;
}

const { post, bodyVNHtml } = Astro.props;
const { title, titleVN, description, descriptionVN, pubDate, category, readTime, tags, tagsVN, cover } = post.data;

function fmt(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const shareURL  = `https://syhai.xyz/blog/${post.slug}`;
const tweetURL  = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(shareURL)}`;
---

<Base title={`${title} — syhai.xyz`} description={description} ogImage={cover}>

  <article class="post">

    <!-- POST HEADER — Bloomberg: category + big headline + deck + byline, THEN image -->
    <div class="post__header">
      <div class="container">

        <!-- Kicker: back link + category -->
        <div class="post__kicker fade-up">
          <a href="/blog" class="post__back" data-lang="en">← All posts</a>
          <a href="/blog" class="post__back" data-lang="vn">← Tất cả bài</a>
          <span class="post__kicker-sep">|</span>
          <span class="tag">{category}</span>
        </div>

        <!-- Headline -->
        <h1 class="post__title fade-up-1" data-lang="en">{title}</h1>
        <h1 class="post__title fade-up-1" data-lang="vn">{titleVN ?? title}</h1>

        <!-- Deck / description (italic) -->
        <p class="post__desc fade-up-2" data-lang="en">{description}</p>
        <p class="post__desc fade-up-2" data-lang="vn">{descriptionVN ?? description}</p>

        <!-- Byline -->
        <div class="post__byline fade-up-3">
          <span class="post__byline-author" data-lang="en">By Sy Hai</span>
          <span class="post__byline-author" data-lang="vn">Bởi Sy Hai</span>
          <span class="post__byline-sep">·</span>
          <span class="post__meta-text">{fmt(pubDate)}</span>
          <span class="post__byline-sep">·</span>
          <span class="post__meta-text" data-lang="en">{readTime} min read</span>
          <span class="post__meta-text" data-lang="vn">{readTime} phút đọc</span>
          <a href={tweetURL} target="_blank" rel="noopener" class="post__share-btn" data-lang="en">Post on X →</a>
          <a href={tweetURL} target="_blank" rel="noopener" class="post__share-btn" data-lang="vn">Chia sẻ lên X →</a>
        </div>

      </div>
    </div>

    <!-- COVER IMAGE — below header, Bloomberg style -->
    <div class="post__cover img-frame">
      {cover
        ? <img src={cover} alt={title} />
        : <div class="img-frame__placeholder">
            <svg width="40" height="40" viewBox="0 0 36 36" fill="none">
              <rect x="3" y="8" width="30" height="20" rx="1" stroke="#999" stroke-width="1.5"/>
              <path d="M3 17l8 7 7-6 10 7" stroke="#999" stroke-width="1"/>
              <circle cx="11" cy="14" r="3" fill="#E5E5E5"/>
            </svg>
            <span data-lang="en">Cover image</span>
            <span data-lang="vn">Ảnh bìa bài viết</span>
          </div>
      }
    </div>

    <!-- BODY -->
    <div class="post__body container">
      <div class="prose" data-lang="en">
        <slot />
      </div>
      {bodyVNHtml && (
        <div class="prose" data-lang="vn" set:html={bodyVNHtml} />
      )}
    </div>

    <!-- POST FOOTER -->
    <footer class="post__footer">
      <div class="container">
        <div class="post__footer-inner">
          <a href="/blog" class="post__footer-back" data-lang="en">← Back to all posts</a>
          <a href="/blog" class="post__footer-back" data-lang="vn">← Quay lại tất cả bài</a>
          <a href={tweetURL} target="_blank" rel="noopener" class="btn" data-lang="en">Share on X →</a>
          <a href={tweetURL} target="_blank" rel="noopener" class="btn" data-lang="vn">Chia sẻ lên X →</a>
        </div>
      </div>
    </footer>

  </article>

</Base>

<style>
/* ── POST HEADER ── */
.post__header {
  padding: 2.5rem 0 2rem;
  border-bottom: 0.5px solid var(--rule);
}

.post__kicker {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.post__back {
  font-family: var(--mono);
  font-size: 0.66rem;
  color: var(--b300);
  letter-spacing: 0.04em;
  transition: color 0.15s;
}
.post__back:hover { color: var(--ink); }
.post__kicker-sep { color: var(--b200); font-family: var(--mono); font-size: 0.66rem; }

.post__title {
  font-size: clamp(2rem, 5.5vw, 3.75rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.05;
  margin-bottom: 1rem;
  color: var(--ink);
}

/* Deck in italic — Bloomberg style */
.post__desc {
  font-size: 1.15rem;
  color: var(--ink2);
  font-family: var(--source);
  font-style: italic;
  line-height: 1.6;
  margin-bottom: 1.5rem;
  max-width: 680px;
}

.post__byline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  border-top: 0.5px solid var(--rule);
  padding-top: 1rem;
}
.post__byline-author {
  font-family: var(--mono);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.post__byline-sep { color: var(--b200); font-family: var(--mono); font-size: 0.7rem; }
.post__meta-text  { font-family: var(--mono); font-size: 0.66rem; color: var(--b300); }

/* ── COVER IMAGE ── */
.post__cover {
  width: 100%;
  height: clamp(260px, 42vw, 460px);
  border-bottom: 0.5px solid var(--rule);
}

/* ── BODY ── */
.post__body { padding: 3rem 0 2.5rem; }

.prose { max-width: 680px; }

.prose :global(h2) {
  font-size: 1.65rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-top: 3rem;
  margin-bottom: 0.75rem;
  padding-top: 1.75rem;
  border-top: 0.5px solid var(--rule);
  color: var(--ink);
}
.prose :global(h3) {
  font-size: 1.2rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-top: 2rem;
  margin-bottom: 0.6rem;
  color: var(--ink);
}
.prose :global(p) {
  font-size: 1.05rem;
  color: var(--ink2);
  line-height: 1.82;
  margin-bottom: 1.3rem;
  font-family: var(--source);
}
.prose :global(ul),
.prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; color: var(--ink2); }
.prose :global(li) { margin-bottom: 0.4rem; line-height: 1.75; font-size: 1rem; font-family: var(--source); }
.prose :global(a)  { color: var(--ink); border-bottom: 1px solid var(--rule); transition: color 0.15s, border-color 0.15s; }
.prose :global(a:hover) { color: var(--accent); border-bottom-color: var(--accent); }
.prose :global(strong)  { color: var(--ink); font-weight: 700; }
.prose :global(img)     { margin: 2rem 0; width: 100%; }
.prose :global(iframe)  { margin: 2rem 0; }

/* Share button in byline */
.post__share-btn {
  font-family: var(--mono);
  font-size: 0.64rem;
  padding: 4px 12px;
  border: 1.5px solid var(--ink);
  color: var(--ink);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  transition: all 0.12s;
  white-space: nowrap;
  font-weight: 600;
}
.post__share-btn:hover { background: var(--ink); color: #fff; }

/* ── POST FOOTER ── */
.post__footer {
  border-top: 0.5px solid var(--rule);
  padding: 1.5rem 0;
  background: var(--b100);
}
.post__footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.post__footer-back {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--b400);
  letter-spacing: 0.04em;
  transition: color 0.15s;
}
.post__footer-back:hover { color: var(--ink); }

@media (max-width: 600px) {
  .post__header { padding: 1.75rem 0 1.5rem; }
  .post__title  { font-size: 1.85rem; }
  .post__desc   { font-size: 1rem; }
}
</style>
