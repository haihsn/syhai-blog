---
import '../styles/global.css';

export interface Props {
  title:       string;
  description?: string;
  ogImage?:    string;
}

const {
  title,
  description = 'AI & crypto research. Building trading systems with Claude. Learning in public.',
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@syngochai" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />}

  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.classList.add('light');
    }
  </script>
</head>

<body>

  <!-- ══ NAV ══ -->
  <nav class="nav">
    <div class="nav__masthead">
      <div class="nav__brand">
        <a href="/" class="nav__logo">syhai.xyz</a>
        <p class="nav__tagline">Learning in public</p>
      </div>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
        <span class="icon-dark">☀</span>
        <span class="icon-light">☾</span>
      </button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- ══ FOOTER ══ -->
  <footer class="footer">
    <div class="footer__inner container--wide">
      <span class="footer__name">syhai.xyz</span>
      <div class="footer__links">
        <a href="/blog">Blog</a>
        <a href="/about">About</a>
        <a href="https://x.com/syngochai" target="_blank" rel="noopener">X</a>
        <a href="/rss.xml">RSS</a>
      </div>
      <span class="footer__copy">© {new Date().getFullYear()} Sy Hai</span>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('theme-toggle');
    toggle?.addEventListener('click', () => {
      document.documentElement.classList.toggle('light');
      localStorage.setItem('theme',
        document.documentElement.classList.contains('light') ? 'light' : 'dark'
      );
    });
  </script>

</body>
</html>

<style>
/* ── NAV ── */
.nav {
  background: var(--bg);
  border-bottom: 0.5px solid var(--rule);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav__masthead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 1.75rem 12px;
  max-width: 1100px;
  margin: 0 auto;
}

.nav__brand {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.nav__logo {
  font-family: var(--playfair);
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -0.04em;
  line-height: 1;
  display: block;
}
.nav__logo:hover { opacity: 0.7; }

.nav__tagline {
  font-family: var(--mono);
  font-size: 0.58rem;
  color: var(--ink2);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

/* Theme toggle */
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 1rem;
  color: var(--ink2);
  padding: 4px 6px;
  line-height: 1;
  transition: color 0.15s;
  flex-shrink: 0;
}
.theme-toggle:hover { color: var(--ink); }
.icon-dark  { display: inline; }
.icon-light { display: none; }
:global(html.light) .icon-dark  { display: none; }
:global(html.light) .icon-light { display: inline; }

/* ── FOOTER ── */
.footer {
  background: var(--bg);
  border-top: 0.5px solid var(--rule);
  padding: 1.5rem 0;
  margin-top: 2rem;
}
.footer__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer__name {
  font-family: var(--playfair);
  font-size: 1rem;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -0.04em;
}
.footer__links {
  display: flex;
  gap: 1.5rem;
}
.footer__links a {
  font-family: var(--mono);
  font-size: 0.63rem;
  color: var(--ink2);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transition: color 0.15s;
}
.footer__links a:hover { color: var(--ink); }
.footer__copy {
  font-family: var(--mono);
  font-size: 0.6rem;
  color: var(--b400);
}

@media (max-width: 600px) {
  .nav__tagline { display: none; }
  .footer__copy { display: none; }
}
</style>
