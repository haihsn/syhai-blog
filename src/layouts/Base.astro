---
import '../styles/global.css';

export interface Props {
  title:       string;
  description?: string;
  ogImage?:    string;
}

const {
  title,
  description = 'AI & crypto research. Building trading systems with Claude. Learning in public.',
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en" id="html-root" class="lang-en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@syngochai" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />}
</head>

<body>

  <!-- ══ NAV ══ -->
  <nav class="nav">

    <!-- Masthead row -->
    <div class="nav__masthead">
      <div class="nav__masthead-left">
        <a href="/" class="nav__logo">syhai.xyz</a>
        <p class="nav__tagline">Learning in public</p>
      </div>

      <!-- EN / VN switcher -->
      <div class="lang-switcher" id="lang-switcher">
        <button class="lang-btn lang-btn--en" onclick="setLang('en')">EN</button>
        <span class="lang-sep">|</span>
        <button class="lang-btn lang-btn--vn" onclick="setLang('vn')">VN</button>
      </div>
    </div>

    <!-- Link row -->
    <div class="nav__links">
      <a href="/"                          data-lang="en">Home</a>
      <a href="/"                          data-lang="vn">Trang chủ</a>
      <a href="/blog?cat=AI+Tutorial"      data-lang="en">AI</a>
      <a href="/blog?cat=AI+Tutorial"      data-lang="vn">AI</a>
      <a href="/blog?cat=Crypto"           data-lang="en">Crypto &amp; Trading</a>
      <a href="/blog?cat=Crypto"           data-lang="vn">Crypto &amp; Trading</a>
      <a href="/blog?cat=Research"         data-lang="en">Research</a>
      <a href="/blog?cat=Research"         data-lang="vn">Nghiên cứu</a>
      <a href="/blog?cat=Poker"            data-lang="en">Poker</a>
      <a href="/blog?cat=Poker"            data-lang="vn">Poker</a>
      <a href="/about"                     data-lang="en">About</a>
      <a href="/about"                     data-lang="vn">Về tôi</a>
      <a href="https://x.com/syngochai" target="_blank" rel="noopener">X →</a>
    </div>

  </nav>

  <main>
    <slot />
  </main>

  <!-- ══ FOOTER ══ -->
  <footer class="footer">
    <div class="footer__inner container--wide">
      <span class="footer__name">syhai.xyz</span>
      <div class="footer__links">
        <a href="/blog"  data-lang="en">Blog</a>
        <a href="/blog"  data-lang="vn">Blog</a>
        <a href="/about" data-lang="en">About</a>
        <a href="/about" data-lang="vn">Về tôi</a>
        <a href="https://x.com/syngochai" target="_blank" rel="noopener">X</a>
        <a href="/rss.xml">RSS</a>
      </div>
      <span class="footer__copy">© {new Date().getFullYear()} Sy Hai</span>
    </div>
  </footer>

</body>
</html>

<!-- ══ LANGUAGE SWITCHER SCRIPT ══ -->
<script is:inline>
  (function() {
    const saved = localStorage.getItem('syhai-lang') || 'en';
    applyLang(saved);
  })();

  function setLang(lang) {
    localStorage.setItem('syhai-lang', lang);
    applyLang(lang);
  }

  function applyLang(lang) {
    const switcher = document.getElementById('lang-switcher');
    if (!switcher) return;
    switcher.classList.toggle('vn-active', lang === 'vn');
    document.documentElement.classList.toggle('lang-en', lang === 'en');
    document.documentElement.classList.toggle('lang-vn', lang === 'vn');
  }

  window.setLang = setLang;
</script>

<style>
/* ── NAV ── */
.nav {
  background: #000;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav__masthead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 1.75rem 12px;
  border-bottom: 0.5px solid rgba(255,255,255,0.1);
  max-width: 1100px;
  margin: 0 auto;
}

.nav__masthead-left {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.nav__logo {
  font-family: 'Inter', sans-serif;
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.04em;
  line-height: 1;
  display: block;
}
.nav__logo:hover { color: #fff; opacity: 0.85; }

.nav__tagline {
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  color: rgba(255,255,255,0.28);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

/* Lang switcher */
.lang-switcher {
  display: flex;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
}
.lang-btn {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  font-weight: 500;
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px 5px;
  letter-spacing: 0.06em;
  transition: color 0.15s;
}
.lang-sep {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: rgba(255,255,255,0.2);
  user-select: none;
}
.lang-btn--en { color: #fff; font-weight: 700; }
.lang-btn--vn { color: rgba(255,255,255,0.3); }
.lang-switcher.vn-active .lang-btn--en { color: rgba(255,255,255,0.3); font-weight: 500; }
.lang-switcher.vn-active .lang-btn--vn { color: #fff; font-weight: 700; }

/* Nav links */
.nav__links {
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 0.5px solid rgba(255,255,255,0.1);
  flex-wrap: nowrap;
  overflow-x: auto;
}
.nav__links a {
  font-family: 'DM Mono', monospace;
  font-size: 0.64rem;
  color: rgba(255,255,255,0.55);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 9px 14px;
  transition: color 0.15s, background 0.15s;
  border-right: 0.5px solid rgba(255,255,255,0.08);
  white-space: nowrap;
}
.nav__links a:first-child { border-left: 0.5px solid rgba(255,255,255,0.08); }
.nav__links a:hover { color: #fff; background: rgba(255,255,255,0.06); }

/* ── FOOTER ── */
.footer {
  background: #000;
  padding: 1.5rem 0;
  margin-top: 5rem;
}
.footer__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer__name {
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.04em;
}
.footer__links {
  display: flex;
  gap: 1.5rem;
}
.footer__links a {
  font-family: 'DM Mono', monospace;
  font-size: 0.63rem;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transition: color 0.15s;
}
.footer__links a:hover { color: #fff; }
.footer__copy {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  color: rgba(255,255,255,0.2);
}

@media (max-width: 600px) {
  .nav__tagline { display: none; }
  .nav__links a { padding: 8px 10px; font-size: 0.58rem; }
  .footer__copy { display: none; }
}
</style>
